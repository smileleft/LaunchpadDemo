<UserControl x:Class="LaunchControl.Views.NavIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border x:Name="bd" Height="58" Background="Transparent" Cursor="Hand"
            BorderBrush="Transparent" BorderThickness="3,0,0,0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="glyph" Text="{Binding Glyph, ElementName=Root}"
                       FontSize="18" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextMuted}"/>
            <TextBlock x:Name="label" Text="{Binding Label, ElementName=Root}"
                       FontSize="8" HorizontalAlignment="Center" Margin="0,3,0,0"
                       Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="LaunchControl.Views.MechanicalFacilitiesPanel"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="92"/></Grid.RowDefinitions>
  <Border Style="{StaticResource Panel}"><Grid Margin="12,0"><TextBlock Text="LAUNCH PAD MECHANICAL FACILITIES" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/><TextBlock Text="SIMULATED TELEMETRY  /  HAZARDOUS COMMANDS DISABLED" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Inhibit}" FontSize="10"/></Grid></Border>
  <Grid Grid.Row="1" Margin="0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="340"/></Grid.ColumnDefinitions>
   <Border Style="{StaticResource Panel}" Margin="0,0,8,0"><Grid><Grid.RowDefinitions><RowDefinition Height="35"/><RowDefinition/></Grid.RowDefinitions><Border Style="{StaticResource HeaderBar}"><TextBlock Text="TRANSPORTER / ERECTOR · SERVICE ARMS · DELUGE" Style="{StaticResource PanelHeader}"/></Border>
    <Canvas Grid.Row="1" Margin="15">
     <Rectangle Canvas.Left="80" Canvas.Top="465" Width="820" Height="18" Fill="{StaticResource Bg3}" Stroke="{StaticResource LineStrong}"/><Rectangle Canvas.Left="455" Canvas.Top="90" Width="42" Height="375" Fill="{StaticResource Bg2}" Stroke="{StaticResource TextSecondary}" StrokeThickness="2"/><Polygon Points="430,90 520,90 475,25" Fill="{StaticResource Bg2}" Stroke="{StaticResource TextSecondary}" StrokeThickness="2"/>
     <TextBlock Canvas.Left="438" Canvas.Top="55" Text="KSLV-X" Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/>
     <Rectangle Canvas.Left="250" Canvas.Top="105" Width="18" Height="360" Fill="{StaticResource Bg2}" Stroke="{StaticResource Info}"/><Rectangle Canvas.Left="268" Canvas.Top="120" Width="165" Height="12" Fill="{StaticResource Info}"/><Rectangle Canvas.Left="268" Canvas.Top="245" Width="165" Height="12" Fill="{StaticResource Info}"/><Rectangle Canvas.Left="268" Canvas.Top="360" Width="165" Height="12" Fill="{StaticResource Info}"/>
     <Border Canvas.Left="285" Canvas.Top="86" Width="124" Height="48" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="SERVICE ARM 1" Style="{StaticResource Tag}"/><TextBlock Text="MATED / LOCKED" Foreground="{StaticResource Go}" FontSize="10" FontWeight="Bold"/></StackPanel></Border>
     <Border Canvas.Left="285" Canvas.Top="211" Width="124" Height="48" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="UMBILICAL ARM" Style="{StaticResource Tag}"/><TextBlock Text="MATED / READY" Foreground="{StaticResource Go}" FontSize="10" FontWeight="Bold"/></StackPanel></Border>
     <Border Canvas.Left="285" Canvas.Top="326" Width="124" Height="48" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="SERVICE ARM 2" Style="{StaticResource Tag}"/><TextBlock Text="MATED / LOCKED" Foreground="{StaticResource Go}" FontSize="10" FontWeight="Bold"/></StackPanel></Border>
     <Rectangle Canvas.Left="590" Canvas.Top="155" Width="18" Height="310" Fill="{StaticResource Bg2}" Stroke="{StaticResource Caution}"/><Line X1="590" Y1="165" X2="500" Y2="460" Stroke="{StaticResource Caution}" StrokeThickness="8"/>
     <Border Canvas.Left="620" Canvas.Top="175" Width="190" Height="92" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Caution}" BorderThickness="1"><StackPanel Margin="12"><TextBlock Text="TRANSPORTER / ERECTOR" Style="{StaticResource Tag}"/><TextBlock Text="{Binding ErectorAngle, StringFormat=ANGLE {0:0.00}°}" Style="{StaticResource Value}"/><TextBlock Text="VERTICAL · LOCK PINS ENGAGED" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Border>
     <Border Canvas.Left="620" Canvas.Top="282" Width="190" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Info}" BorderThickness="1"><StackPanel Margin="12"><TextBlock Text="HYDRAULIC POWER UNIT" Style="{StaticResource Tag}"/><TextBlock Text="{Binding ErectorHydraulicPressure, StringFormat={}{0:0.0} MPa}" Style="{StaticResource Value}"/><TextBlock Text="PUMP A READY · PUMP B STBY" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Border>
     <Border Canvas.Left="80" Canvas.Top="325" Width="135" Height="140" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Info}" BorderThickness="1"><Grid><Rectangle VerticalAlignment="Bottom" Height="105" Fill="#263DBEE6"/><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="DELUGE TANK" Style="{StaticResource Tag}"/><TextBlock Text="{Binding WaterTankLevel, StringFormat={}{0:0.0}%}" Style="{StaticResource Value}"/><TextBlock Text="READY" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Grid></Border>
     <Rectangle Canvas.Left="147" Canvas.Top="295" Width="4" Height="30" Fill="{StaticResource Info}"/><Rectangle Canvas.Left="147" Canvas.Top="295" Width="300" Height="4" Fill="{StaticResource Info}"/><TextBlock Canvas.Left="170" Canvas.Top="276" Text="DELUGE HEADER" Style="{StaticResource Tag}"/>
     <Border Canvas.Left="610" Canvas.Top="405" Width="210" Height="60" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="FLAME DEFLECTOR" Style="{StaticResource Tag}"/><TextBlock Text="{Binding FlameDeflectorTemperature, StringFormat=DECK TEMP {0:0.0} °C}" Foreground="{StaticResource Go}"/></StackPanel></Border>
    </Canvas></Grid></Border>
   <StackPanel Grid.Column="1">
    <Border Style="{StaticResource Panel}" Margin="0,0,0,8"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="POSITION / PRESSURE" Style="{StaticResource PanelHeader}"/></Border><Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="30"/><RowDefinition Height="30"/><RowDefinition Height="30"/><RowDefinition Height="30"/><RowDefinition Height="30"/></Grid.RowDefinitions><TextBlock Text="Erector angle" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Column="1" Text="{Binding ErectorAngle, StringFormat={}{0:0.00}°}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="1" Text="HPU pressure" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ErectorHydraulicPressure, StringFormat={}{0:0.0} MPa}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="2" Text="Arm position" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ServiceArmPosition, StringFormat={}{0:0.0}% MATED}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="3" Text="Deluge tank" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WaterTankLevel, StringFormat={}{0:0.0}%}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="4" Text="Deluge pressure" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DelugePressure, StringFormat={}{0:0.00} MPa}" Style="{StaticResource Mono}"/></Grid></StackPanel></Border>
    <Border Style="{StaticResource Panel}" Margin="0,0,0,8"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="MECHANICAL INTERLOCKS" Style="{StaticResource PanelHeader}"/></Border><StackPanel Margin="12"><TextBlock Text="✓ T/E VERTICAL LOCKED" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ ARM LOCK PINS ENGAGED" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ UMBILICAL MATED" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ HOLD-DOWN CLAMPS CLOSED" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="● RELEASE COMMAND INHIBITED" Foreground="{StaticResource Inhibit}" Margin="0,4"/></StackPanel></StackPanel></Border>
    <Border Style="{StaticResource Panel}"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="FACILITY STATUS" Style="{StaticResource PanelHeader}"/></Border><Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="28"/><RowDefinition Height="28"/><RowDefinition Height="28"/></Grid.RowDefinitions><TextBlock Text="Deluge system" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Column="1" Text="ARMED" Foreground="{StaticResource Go}"/><TextBlock Grid.Row="1" Text="Flame trench" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="1" Grid.Column="1" Text="CLEAR" Foreground="{StaticResource Go}"/><TextBlock Grid.Row="2" Text="Active alarms" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="2" Grid.Column="1" Text="0" Foreground="{StaticResource Go}"/></Grid></StackPanel></Border>
   </StackPanel>
  </Grid>
  <Border Grid.Row="2" Style="{StaticResource Panel}"><Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions><Border Style="{StaticResource HeaderBar}"><TextBlock Text="MECHANICAL COMMANDS  ·  DEMO / READ-ONLY SAFETY GATE" Style="{StaticResource PanelHeader}"/></Border><UniformGrid Grid.Row="1" Columns="6" Margin="10"><Button Content="ARM RETRACT" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="T/E LOWER" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="HPU START" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="DELUGE TEST" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="RELEASE ARM" Style="{StaticResource HoldButton}" Margin="4" IsEnabled="False"/><Button Content="MECH E-STOP" Style="{StaticResource AbortButton}" Margin="4" IsEnabled="False"/></UniformGrid></Grid></Border>
 </Grid>
</UserControl>

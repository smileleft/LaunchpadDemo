<UserControl x:Class="LaunchControl.Views.PowerSystemPanel"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid>
  <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="92"/></Grid.RowDefinitions>
  <Border Style="{StaticResource Panel}"><Grid Margin="12,0"><TextBlock Text="ELECTRICAL POWER SYSTEM  ·  SINGLE-LINE OVERVIEW" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/><TextBlock Text="SIMULATED TELEMETRY  /  CONTROL DISABLED" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Inhibit}" FontSize="10"/></Grid></Border>
  <Grid Grid.Row="1" Margin="0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="330"/></Grid.ColumnDefinitions>
   <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,8,0">
    <Grid><Grid.RowDefinitions><RowDefinition Height="35"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <Border Style="{StaticResource HeaderBar}"><TextBlock Text="AC / UPS / DC DISTRIBUTION" Style="{StaticResource PanelHeader}"/></Border>
     <Canvas Grid.Row="1" Margin="15">
      <Rectangle Canvas.Left="55" Canvas.Top="65" Width="150" Height="75" Fill="{StaticResource Bg2}" Stroke="{StaticResource Info}"/>
      <TextBlock Canvas.Left="78" Canvas.Top="78" Text="UTILITY INCOMING" Style="{StaticResource Tag}"/><TextBlock Canvas.Left="77" Canvas.Top="99" Text="{Binding UtilityVoltage, StringFormat={}{0:0.0} V AC}" Style="{StaticResource Value}"/><TextBlock Canvas.Left="102" Canvas.Top="121" Text="{Binding UtilityFrequency, StringFormat={}{0:0.00} Hz}" Style="{StaticResource Mono}"/>
      <Rectangle Canvas.Left="205" Canvas.Top="101" Width="105" Height="4" Fill="{StaticResource Info}"/><Border Canvas.Left="286" Canvas.Top="88" Width="42" Height="30" Background="{StaticResource GoDim}" BorderBrush="{StaticResource Go}" BorderThickness="1"><TextBlock Text="CB-01\nCLOSED" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Go}" FontSize="8" TextAlignment="Center"/></Border>
      <Rectangle Canvas.Left="328" Canvas.Top="101" Width="115" Height="4" Fill="{StaticResource Info}"/>
      <Border Canvas.Left="443" Canvas.Top="58" Width="165" Height="94" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="UPS-01  ONLINE" Foreground="{StaticResource Go}" FontWeight="Bold"/><TextBlock Text="{Binding UpsLoad, StringFormat=LOAD {0:0.0}%}" Style="{StaticResource Mono}" Margin="0,8,0,0"/><TextBlock Text="{Binding UpsRuntime, StringFormat=RUNTIME {0:0} min}" Foreground="{StaticResource TextSecondary}" FontSize="10"/></StackPanel></Border>
      <Rectangle Canvas.Left="608" Canvas.Top="101" Width="120" Height="4" Fill="{StaticResource Go}"/><Border Canvas.Left="728" Canvas.Top="70" Width="165" Height="70" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="CRITICAL AC BUS" Style="{StaticResource Tag}"/><TextBlock Text="ENERGIZED" Foreground="{StaticResource Go}" FontWeight="Bold" FontSize="16"/></StackPanel></Border>
      <Rectangle Canvas.Left="525" Canvas.Top="152" Width="4" Height="96" Fill="{StaticResource Info}"/><Border Canvas.Left="452" Canvas.Top="248" Width="154" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Info}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="RECTIFIER / CHARGER" Style="{StaticResource Tag}"/><TextBlock Text="{Binding DcBusVoltage, StringFormat={}{0:0.00} V DC}" Style="{StaticResource Value}"/><TextBlock Text="FLOAT MODE" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Border>
      <Rectangle Canvas.Left="606" Canvas.Top="286" Width="122" Height="4" Fill="{StaticResource Info}"/><Border Canvas.Left="728" Canvas.Top="248" Width="165" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Info}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="28 VDC CONTROL BUS" Style="{StaticResource Tag}"/><TextBlock Text="{Binding DcBusVoltage, StringFormat={}{0:0.00} V}" Style="{StaticResource Value}"/><TextBlock Text="DUAL FEED HEALTHY" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Border>
      <Border Canvas.Left="55" Canvas.Top="248" Width="150" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Caution}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="GENSET-01 STANDBY" Foreground="{StaticResource Caution}" FontWeight="Bold"/><TextBlock Text="{Binding GeneratorLoad, StringFormat=TEST LOAD {0:0.0}%}" Style="{StaticResource Mono}" Margin="0,8,0,0"/></StackPanel></Border><Rectangle Canvas.Left="205" Canvas.Top="286" Width="247" Height="4" Fill="{StaticResource Caution}"/>
      <Border Canvas.Left="55" Canvas.Top="390" Width="215" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="FLIGHT BATTERY INTERFACE" Style="{StaticResource Tag}"/><TextBlock Text="{Binding FlightBatteryVoltage, StringFormat={}{0:0.00} V}" Style="{StaticResource Value}"/><TextBlock Text="CONNECTED · CHARGE NORMAL" Foreground="{StaticResource Go}" FontSize="10"/></StackPanel></Border>
      <Rectangle Canvas.Left="270" Canvas.Top="429" Width="458" Height="4" Fill="{StaticResource Go}"/><Border Canvas.Left="728" Canvas.Top="390" Width="165" Height="82" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Go}" BorderThickness="1"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="VEHICLE POWER" Style="{StaticResource Tag}"/><TextBlock Text="GROUND FEED" Foreground="{StaticResource Go}" FontWeight="Bold"/><TextBlock Text="UMBILICAL MATED" Foreground="{StaticResource TextSecondary}" FontSize="10"/></StackPanel></Border>
     </Canvas>
    </Grid>
   </Border>
   <StackPanel Grid.Column="1">
    <Border Style="{StaticResource Panel}" Margin="0,0,0,8"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="POWER QUALITY" Style="{StaticResource PanelHeader}"/></Border><Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="30"/><RowDefinition Height="30"/><RowDefinition Height="30"/><RowDefinition Height="30"/></Grid.RowDefinitions><TextBlock Text="Utility voltage" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Column="1" Text="{Binding UtilityVoltage, StringFormat={}{0:0.0} V}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="1" Text="Frequency" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UtilityFrequency, StringFormat={}{0:0.00} Hz}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="2" Text="UPS load" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UpsLoad, StringFormat={}{0:0.0}%}" Style="{StaticResource Mono}"/><TextBlock Grid.Row="3" Text="DC bus" Foreground="{StaticResource TextSecondary}"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DcBusVoltage, StringFormat={}{0:0.00} V}" Style="{StaticResource Mono}"/></Grid></StackPanel></Border>
    <Border Style="{StaticResource Panel}" Margin="0,0,0,8"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="FEEDER STATUS" Style="{StaticResource PanelHeader}"/></Border><StackPanel Margin="12"><TextBlock Text="✓ MAIN SWITCHGEAR HEALTHY" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ UPS BYPASS AVAILABLE" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ DC CHARGER A/B HEALTHY" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="✓ VEHICLE GROUND POWER MATED" Foreground="{StaticResource Go}" Margin="0,4"/><TextBlock Text="● REMOTE BREAKER COMMAND INHIBITED" Foreground="{StaticResource Inhibit}" Margin="0,4"/></StackPanel></StackPanel></Border>
    <Border Style="{StaticResource Panel}"><StackPanel><Border Style="{StaticResource HeaderBar}"><TextBlock Text="ACTIVE ALARMS" Style="{StaticResource PanelHeader}"/></Border><TextBlock Text="0  ·  NO ACTIVE ELECTRICAL ALARMS" Foreground="{StaticResource Go}" Margin="12,16"/></StackPanel></Border>
   </StackPanel>
  </Grid>
  <Border Grid.Row="2" Style="{StaticResource Panel}"><Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions><Border Style="{StaticResource HeaderBar}"><TextBlock Text="POWER COMMANDS  ·  DEMO / READ-ONLY SAFETY GATE" Style="{StaticResource PanelHeader}"/></Border><UniformGrid Grid.Row="1" Columns="6" Margin="10"><Button Content="UPS TRANSFER" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="GENSET START" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="FEEDER CLOSE" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="DC BUS RESET" Style="{StaticResource CmdButton}" Margin="4" IsEnabled="False"/><Button Content="VEHICLE POWER OFF" Style="{StaticResource HoldButton}" Margin="4" IsEnabled="False"/><Button Content="POWER TRIP" Style="{StaticResource AbortButton}" Margin="4" IsEnabled="False"/></UniformGrid></Grid></Border>
 </Grid>
</UserControl>

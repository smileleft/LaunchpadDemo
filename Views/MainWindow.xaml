<Window x:Class="LaunchControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LaunchControl.ViewModels"
        xmlns:conv="clr-namespace:LaunchControl.Converters"
        xmlns:v="clr-namespace:LaunchControl.Views"
        Title="LAUNCH CONTROL CONSOLE" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg0}"
        FontFamily="{StaticResource FontUI}">

    <Window.DataContext>
        <vm:ConsoleViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StatusLevelToBrush x:Key="LvlBrush"/>
        <conv:StatusLevelToText  x:Key="LvlText"/>
        <conv:EnumEquals         x:Key="EnumEq"/>
        <conv:BoolToVis          x:Key="BoolVis"/>
        <conv:StepStateToRowBrush x:Key="RowBrush"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- mission header -->
            <RowDefinition Height="*"/>    <!-- body -->
            <RowDefinition Height="26"/>   <!-- status strip -->
        </Grid.RowDefinitions>

        <!-- ============================= MISSION HEADER ============================= -->
        <Border Grid.Row="0" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource Go}" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding MissionName}" Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ops mode segmented -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Text="MODE" Foreground="{StaticResource TextMuted}" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TEST"        Padding="10,4" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="MAINT"       Padding="10,4" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <Border Background="{StaticResource InfoDim}" BorderBrush="{StaticResource Info}" BorderThickness="1">
                                <TextBlock Text="LAUNCH" Padding="10,4" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Info}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,16,0" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding UtcClock}" Style="{StaticResource Mono}" FontSize="13"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Operator}" Foreground="{StaticResource TextMuted}" FontSize="10"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================= BODY ============================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>    <!-- nav rail -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation rail: only Overview enabled for now; others staged -->
            <Border Grid.Column="0" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <v:NavIcon x:Name="NavOverview" Glyph="&#x25A6;" Label="OVR" IsActive="True" Click="ShowConsole"/>
                    <v:NavIcon x:Name="NavReadiness" Glyph="&#x2637;" Label="LRM" Click="ShowConsole"/>
                    <v:NavIcon x:Name="NavSequencer" Glyph="&#x23F1;" Label="SEQ" Click="ShowConsole"/>
                    <v:NavIcon x:Name="NavPropellant" Glyph="&#x2699;" Label="PROP" Click="ShowPropellant"/>
                    <v:NavIcon x:Name="NavPressPurge" Glyph="&#x21C4;" Label="P/P" Click="ShowPressPurge"/>
                    <v:NavIcon x:Name="NavPower" Glyph="&#x26A1;" Label="PWR" Click="ShowPower"/>
                    <v:NavIcon x:Name="NavMechanical" Glyph="&#x2692;" Label="MECH" Click="ShowMechanical"/>
                    <v:NavIcon Glyph="&#x25B2;" Label="TRND"/>
                    <v:NavIcon Glyph="&#x26A0;" Label="ALM"/>
                    <v:NavIcon Glyph="&#x1F512;" Label="ILK"/>
                </ItemsControl>
            </Border>

            <!-- Main console and navigable subsystem pages -->
            <Grid x:Name="ConsolePage" Grid.Column="1" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" MinWidth="320"/>  <!-- Overview -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>                    <!-- Readiness -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="380" MinWidth="340"/>   <!-- Sequencer -->
                </Grid.ColumnDefinitions>

                <v:OverviewPanel  Grid.Column="0"/>
                <v:ReadinessPanel Grid.Column="2"/>
                <v:SequencerPanel Grid.Column="4"/>
            </Grid>

            <v:PropellantPanel x:Name="PropellantPage" Grid.Column="1" Margin="8" Visibility="Collapsed"/>
            <v:PressurizationPurgePanel x:Name="PressPurgePage" Grid.Column="1" Margin="8" Visibility="Collapsed"/>
            <v:PowerSystemPanel x:Name="PowerPage" Grid.Column="1" Margin="8" Visibility="Collapsed"/>
            <v:MechanicalFacilitiesPanel x:Name="MechanicalPage" Grid.Column="1" Margin="8" Visibility="Collapsed"/>
        </Grid>

        <!-- ============================= STATUS STRIP ============================= -->
        <Border Grid.Row="2" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OVERALL" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Background="{Binding OverallLevel, Converter={StaticResource LvlBrush}}" Padding="8,1" CornerRadius="2">
                        <TextBlock Text="{Binding OverallReadiness}" Foreground="{StaticResource Bg0}" FontWeight="Bold" FontSize="11"/>
                    </Border>
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Run Text="GO "/><Run Text="{Binding GoCount, Mode=OneWay}" Foreground="{StaticResource Go}"/>
                        <Run Text="   HOLD "/><Run Text="{Binding HoldCount, Mode=OneWay}" Foreground="{StaticResource Caution}"/>
                        <Run Text="   NO-GO "/><Run Text="{Binding NoGoCount, Mode=OneWay}" Foreground="{StaticResource NoGo}"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="ANTHROPIC LAUNCH CONTROL  ·  DEMO BUILD  ·  SIMULATED TELEMETRY"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>

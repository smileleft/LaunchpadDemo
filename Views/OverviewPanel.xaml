<UserControl x:Class="LaunchControl.Views.OverviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LaunchControl.Converters">
    <UserControl.Resources>
        <conv:StatusLevelToBrush x:Key="LvlBrush"/>
        <conv:StatusLevelToText  x:Key="LvlText"/>
        <conv:BoolToVis          x:Key="BoolVis"/>
    </UserControl.Resources>

    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
                <Grid>
                    <TextBlock Text="발사대 OVERVIEW" Style="{StaticResource PanelHeader}"/>
                    <TextBlock Text="PAD-2 SUBSYSTEMS" Style="{StaticResource PanelHeader}"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl ItemsSource="{Binding Subsystems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}"
                                    BorderThickness="1" Margin="3" Padding="0" Height="112">
                                <Grid>
                                    <!-- left status bar -->
                                    <Border Width="4" HorizontalAlignment="Left" Background="{Binding Accent}"/>
                                    <Grid Margin="12,8,10,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- name + state chip -->
                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                            <Border HorizontalAlignment="Right" Padding="5,1" CornerRadius="2"
                                                    Background="{Binding Level, Converter={StaticResource LvlBrush}}">
                                                <TextBlock Text="{Binding Level, Converter={StaticResource LvlText}}"
                                                           Foreground="{StaticResource Bg0}" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>

                                        <!-- primary value -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PrimaryValue}" FontFamily="{StaticResource FontMono}"
                                                       FontSize="26" Foreground="{Binding Accent}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PrimaryUnit}" FontSize="10"
                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom"
                                                       Margin="6,0,0,4"/>
                                        </StackPanel>

                                        <!-- detail + alarm -->
                                        <Grid Grid.Row="2">
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            <Border HorizontalAlignment="Right" Background="{StaticResource NoGoDim}"
                                                    BorderBrush="{StaticResource NoGo}" BorderThickness="1" Padding="4,0"
                                                    CornerRadius="2" Visibility="{Binding HasAlarms, Converter={StaticResource BoolVis}}">
                                                <TextBlock Foreground="{StaticResource NoGo}" FontSize="9">
                                                    <Run Text="&#x26A0; "/><Run Text="{Binding ActiveAlarms, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

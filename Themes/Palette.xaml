<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==== Surface / background layers ==== -->
    <Color x:Key="Bg0Color">#0A0E14</Color>   <!-- app backdrop -->
    <Color x:Key="Bg1Color">#111722</Color>   <!-- panel -->
    <Color x:Key="Bg2Color">#182130</Color>   <!-- raised panel / header -->
    <Color x:Key="Bg3Color">#22303F</Color>   <!-- hover / cell -->
    <Color x:Key="LineColor">#2A3644</Color>  <!-- hairline borders -->
    <Color x:Key="LineStrongColor">#3A4A5C</Color>

    <SolidColorBrush x:Key="Bg0" Color="{StaticResource Bg0Color}"/>
    <SolidColorBrush x:Key="Bg1" Color="{StaticResource Bg1Color}"/>
    <SolidColorBrush x:Key="Bg2" Color="{StaticResource Bg2Color}"/>
    <SolidColorBrush x:Key="Bg3" Color="{StaticResource Bg3Color}"/>
    <SolidColorBrush x:Key="Line" Color="{StaticResource LineColor}"/>
    <SolidColorBrush x:Key="LineStrong" Color="{StaticResource LineStrongColor}"/>

    <!-- ==== Text ==== -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#9BA9B8"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#5C6B7A"/>

    <!-- ==== Status semantics ==== -->
    <Color x:Key="GoColor">#2FD07A</Color>       <!-- GO / nominal -->
    <Color x:Key="CautionColor">#F5C542</Color>  <!-- caution / hold -->
    <Color x:Key="NoGoColor">#FF5C5C</Color>     <!-- no-go / fault -->
    <Color x:Key="InfoColor">#3DBEE6</Color>     <!-- info / active telemetry -->
    <Color x:Key="InhibitColor">#B57BFF</Color>  <!-- inhibit / interlock -->
    <Color x:Key="StandbyColor">#6C7A89</Color>  <!-- offline / standby -->

    <SolidColorBrush x:Key="Go"       Color="{StaticResource GoColor}"/>
    <SolidColorBrush x:Key="Caution"  Color="{StaticResource CautionColor}"/>
    <SolidColorBrush x:Key="NoGo"     Color="{StaticResource NoGoColor}"/>
    <SolidColorBrush x:Key="Info"     Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="Inhibit"  Color="{StaticResource InhibitColor}"/>
    <SolidColorBrush x:Key="Standby"  Color="{StaticResource StandbyColor}"/>

    <!-- dim fills for status backgrounds -->
    <SolidColorBrush x:Key="GoDim"      Color="#123024"/>
    <SolidColorBrush x:Key="CautionDim" Color="#33290A"/>
    <SolidColorBrush x:Key="NoGoDim"    Color="#361417"/>
    <SolidColorBrush x:Key="InfoDim"    Color="#0F2A34"/>
    <SolidColorBrush x:Key="InhibitDim" Color="#241833"/>

    <!-- accent -->
    <SolidColorBrush x:Key="Accent" Color="#3DBEE6"/>

    <!-- ==== Typography ==== -->
    <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">Consolas</FontFamily>

</ResourceDictionary>
